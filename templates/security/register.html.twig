<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Sign Up | FinanceLogo</title>

    <link rel="stylesheet" href="{{ asset('css/auth.css') }}">
    <link rel="stylesheet" href="{{ asset('css/dark-mode.css') }}">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .captcha-wrap {
            grid-column: span 2;
        }

        .captcha-image-box {
            background: #e5e7eb;
            border: 1px solid #9ca3af;
            border-radius: 8px;
            padding: 8px;
            max-width: 290px;
        }

        .captcha-image {
            display: block;
            width: 100%;
            height: auto;
            border: 1px solid #cbd5e1;
            background: #f3f4f6;
        }

        .captcha-tools {
            margin-top: 8px;
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .captcha-refresh {
            border: 0;
            border-radius: 6px;
            padding: 6px 10px;
            background: #0ea5e9;
            color: #fff;
            cursor: pointer;
            font-size: 0.85rem;
        }

        .faceid-wrap {
            grid-column: span 2;
            margin-top: 6px;
        }

        .faceid-btn {
            border: 0;
            border-radius: 8px;
            padding: 8px 12px;
            background: #334155;
            color: #fff;
            cursor: pointer;
            font-size: 0.9rem;
        }

        .faceid-status {
            margin-top: 8px;
            font-size: 0.9rem;
            color: #94a3b8;
        }

        .faceid-status.ok {
            color: #16a34a;
        }

        .faceid-status.error {
            color: #dc2626;
        }

        .facepp-video {
            width: 100%;
            max-width: 320px;
            border-radius: 8px;
            border: 1px solid #334155;
            background: #0f172a;
            margin-top: 8px;
        }

        .facepp-actions {
            margin-top: 8px;
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .email-status {
            margin-top: 6px;
            font-size: 0.85rem;
            min-height: 18px;
            color: #94a3b8;
        }

        .email-status.ok {
            color: #16a34a;
        }

        .email-status.error {
            color: #dc2626;
        }
    </style>
</head>
<body>

<div class="auth-page" style="background-image: url('{{ asset('img/a2.jpg') }}');">
    <div class="overlay"></div>

    <div class="auth-container">

        <div class="auth-left">
            <div class="brand">
                <img src="{{ asset('img/chat1.png') }}" alt="DECIDE$ Logo" class="brand-logo animate-logo">
            </div>

            <h2>
                Join us and manage<br>
                <span>your financial future</span>
            </h2>

            <div class="accent-line"></div>

            <p class="side-text">
                Optimize investments and monitor your balance in real time with advanced tools.
            </p>
        </div>

        <div class="auth-right">
            <div class="auth-card register">

                <h2>Sign Up</h2>
                <p class="subtitle">Create your secure account</p>

                {% for message in app.flashes('error') %}
                    <div class="error-message mb-2">
                        <i class="fas fa-exclamation-circle"></i>
                        {{ message }}
                    </div>
                {% endfor %}

                <form method="post" class="register-grid">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('register') }}">
                    <input type="hidden" name="faceid_credential_id" id="faceid-credential-id" value="">
                    <input type="hidden" name="facepp_token" id="facepp-token" value="">

                    <div class="input-group">
                        <label>Full name</label>
                        <input type="text" name="nom" placeholder="Full name" minlength="2" maxlength="100" required value="{{ form_data.nom|default('') }}">
                    </div>

                    <div class="input-group">
                        <label>Email</label>
                        <input type="email" name="email" placeholder="Email" maxlength="180" required value="{{ form_data.email|default('') }}">
                        <div id="email-validate-status" class="email-status"></div>
                    </div>

                    <div class="input-group">
                        <label>Password</label>
                        <input type="password" name="password" placeholder="Password" minlength="8" maxlength="255" required>
                        <small class="text-muted">At least 8 characters, with uppercase, lowercase and a number.</small>
                    </div>

                    <div class="input-group">
                        <label>Confirm password</label>
                        <input type="password" name="confirm_password" placeholder="Confirm password" minlength="8" maxlength="255" required>
                    </div>

                    <div class="input-group">
                        <label>Role</label>
                        <select name="role" required>
                            <option value="">Choose a role</option>
                            <option value="ETUDIANT" {{ form_data.role|default('') == 'ETUDIANT' ? 'selected' : '' }}>Student</option>
                            <option value="SALARIE" {{ form_data.role|default('') == 'SALARIE' ? 'selected' : '' }}>Employee</option>
                        </select>
                    </div>

                    <div class="input-group">
                        <label>Initial balance</label>
                        <input type="number" name="solde" placeholder="0" value="{{ form_data.solde|default('0') }}" min="0" step="0.01" required>
                    </div>

                    <div class="input-group captcha-wrap">
                        <label>Anti-robot verification</label>
                        <small class="text-muted">To continue, type the characters you see in the picture.</small>
                        <div class="captcha-image-box">
                            <img id="captcha-image" class="captcha-image" src="{{ path('app_register_captcha_image') }}?v={{ random() }}" alt="Captcha">
                        </div>
                        <div class="captcha-tools">
                            <button type="button" id="captcha-refresh" class="captcha-refresh">New code</button>
                        </div>
                        <input type="text" name="captcha_input" placeholder="Type captcha code" maxlength="8" required autocomplete="off" style="margin-top:8px; text-transform: uppercase;">
                    </div>

                    <div class="input-group faceid-wrap">
                        <label>Face ID (optional)</label>
                        <button type="button" id="faceid-register-btn" class="faceid-btn">Enable Face ID on this device</button>
                        <div id="faceid-register-status" class="faceid-status"></div>
                    </div>

                    <div class="input-group faceid-wrap">
                        <label>Face++ (optional)</label>
                        <video id="facepp-register-video" class="facepp-video" autoplay playsinline muted></video>
                        <canvas id="facepp-register-canvas" style="display:none;"></canvas>
                        <div class="facepp-actions">
                            <button type="button" id="facepp-register-start-btn" class="faceid-btn">Open camera</button>
                            <button type="button" id="facepp-register-btn" class="faceid-btn">Capture and register</button>
                            <button type="button" id="facepp-register-stop-btn" class="faceid-btn">Stop camera</button>
                        </div>
                        <div id="facepp-register-status" class="faceid-status"></div>
                    </div>

                    <button type="submit" class="btn-auth full-width">
                        SIGN UP
                    </button>
                </form>

                <div class="auth-footer">
                    Already have an account?
                    <a href="{{ path('app_login') }}">Sign in</a>
                </div>

                <div class="ssl-badge">
                    <i class="fas fa-lock"></i> SSL SECURED
                </div>

            </div>
        </div>

    </div>
</div>

<script src="{{ asset('js/theme-toggle.js') }}"></script>
<script>
    (() => {
        const form = document.querySelector('form.register-grid');
        const emailInput = form ? form.querySelector('input[name="email"]') : null;
        const status = document.getElementById('email-validate-status');
        if (!form || !emailInput || !status) {
            return;
        }

        let timer = null;
        let isChecking = false;
        let abortController = null;
        let lastCheckedEmail = '';
        let lastCheckResult = null;
        let submitBypass = false;

        const setStatus = (text, kind = '') => {
            status.textContent = text;
            status.classList.remove('ok', 'error');
            if (kind) {
                status.classList.add(kind);
            }
        };

        const isEmailFormatValid = (email) => {
            if (email.length === 0 || email.length > 180) {
                return false;
            }
            return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
        };

        const applyValidity = (message) => {
            emailInput.setCustomValidity(message || '');
        };

        const checkEmail = async (force = false) => {
            const raw = emailInput.value.trim();
            const email = raw.toLowerCase();

            if (!force && email === '') {
                setStatus('');
                applyValidity('');
                return null;
            }

            if (!isEmailFormatValid(email)) {
                setStatus(email === '' ? '' : 'Invalid email format.', 'error');
                applyValidity(email === '' ? '' : 'Invalid email format.');
                lastCheckedEmail = '';
                lastCheckResult = null;
                return false;
            }

            if (!force && lastCheckedEmail === email && lastCheckResult !== null) {
                if (lastCheckResult.available) {
                    setStatus('Email is available.', 'ok');
                    applyValidity('');
                    return true;
                }
                setStatus(lastCheckResult.message || 'Email is already used.', 'error');
                applyValidity(lastCheckResult.message || 'Email is already used.');
                return false;
            }

            if (abortController) {
                abortController.abort();
            }
            abortController = new AbortController();
            isChecking = true;
            setStatus('Checking email...');
            applyValidity('Checking email availability...');

            try {
                const res = await fetch('{{ path('api_email_validate') }}', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                    body: JSON.stringify({ email }),
                    signal: abortController.signal,
                });
                const data = await res.json();
                if (!res.ok || !data.success) {
                    setStatus(data.message || 'Email validation failed.', 'error');
                    applyValidity(data.message || 'Email validation failed.');
                    lastCheckedEmail = email;
                    lastCheckResult = { available: false, message: data.message || 'Email validation failed.' };
                    return false;
                }

                const ok = !!data.valid && !!data.available;
                if (ok) {
                    setStatus(data.message || 'Email is available.', 'ok');
                    applyValidity('');
                } else {
                    setStatus(data.message || 'Email is not available.', 'error');
                    applyValidity(data.message || 'Email is not available.');
                }
                lastCheckedEmail = email;
                lastCheckResult = {
                    available: !!data.available,
                    valid: !!data.valid,
                    message: data.message || '',
                };
                return ok;
            } catch (e) {
                if (e && e.name === 'AbortError') {
                    return null;
                }
                setStatus('Cannot validate email right now.', 'error');
                applyValidity('Cannot validate email right now.');
                lastCheckedEmail = '';
                lastCheckResult = null;
                return false;
            } finally {
                isChecking = false;
            }
        };

        emailInput.addEventListener('input', () => {
            emailInput.value = emailInput.value.trimStart();
            applyValidity('');
            setStatus('');
            lastCheckedEmail = '';
            lastCheckResult = null;

            if (timer) {
                clearTimeout(timer);
            }

            const email = emailInput.value.trim();
            if (email === '') {
                return;
            }

            timer = setTimeout(() => {
                checkEmail(false);
            }, 450);
        });

        emailInput.addEventListener('blur', () => {
            checkEmail(true);
        });

        form.addEventListener('submit', async (e) => {
            if (submitBypass) {
                return;
            }

            e.preventDefault();

            if (timer) {
                clearTimeout(timer);
                timer = null;
            }
            if (isChecking) {
                setStatus('Please wait, checking email...');
                applyValidity('Please wait, checking email...');
                emailInput.reportValidity();
                return;
            }
            const ok = await checkEmail(true);
            if (!ok) {
                emailInput.reportValidity();
                return;
            }

            const confirmed = window.confirm('Confirm registration with this information?');
            if (!confirmed) {
                return;
            }

            submitBypass = true;
            form.submit();
        });
    })();

    (() => {
        const btn = document.getElementById('captcha-refresh');
        const img = document.getElementById('captcha-image');
        if (!btn || !img) {
            return;
        }

        btn.addEventListener('click', () => {
            img.src = '{{ path('app_register_captcha_image') }}?refresh=1&v=' + Date.now();
        });
    })();

    (() => {
        const btn = document.getElementById('faceid-register-btn');
        const status = document.getElementById('faceid-register-status');
        const credentialInput = document.getElementById('faceid-credential-id');
        const emailInput = document.querySelector('input[name="email"]');
        if (!btn || !status || !credentialInput || !emailInput) {
            return;
        }

        const setStatus = (text, kind = '') => {
            status.textContent = text;
            status.classList.remove('ok', 'error');
            if (kind) {
                status.classList.add(kind);
            }
        };

        const toBase64Url = (bytes) => {
            let binary = '';
            bytes.forEach((b) => { binary += String.fromCharCode(b); });
            return btoa(binary).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/g, '');
        };

        const isIpHost = (host) => /^(\d{1,3}\.){3}\d{1,3}$/.test(host) || host.includes(':');

        btn.addEventListener('click', async () => {
            try {
                if (!window.PublicKeyCredential || !navigator.credentials) {
                    setStatus('Face ID is not supported on this browser.', 'error');
                    return;
                }
                if (!window.isSecureContext) {
                    setStatus('Face ID requires a secure context (HTTPS or localhost).', 'error');
                    return;
                }
                if (isIpHost(window.location.hostname)) {
                    setStatus('Use http://localhost:8000 instead of 127.0.0.1 to enable Face ID.', 'error');
                    return;
                }
                if (PublicKeyCredential.isUserVerifyingPlatformAuthenticatorAvailable) {
                    const available = await PublicKeyCredential.isUserVerifyingPlatformAuthenticatorAvailable();
                    if (!available) {
                        setStatus('No local authenticator detected. You can still use a passkey from phone/security key.');
                    }
                }

                const email = emailInput.value.trim();
                if (!email) {
                    setStatus('Please enter your email first.', 'error');
                    return;
                }

                const challenge = new Uint8Array(32);
                crypto.getRandomValues(challenge);
                const userId = new TextEncoder().encode(email.toLowerCase());

                const credential = await navigator.credentials.create({
                    publicKey: {
                        challenge,
                        rp: { name: 'Decide$' },
                        user: {
                            id: userId,
                            name: email.toLowerCase(),
                            displayName: email.toLowerCase(),
                        },
                        pubKeyCredParams: [{ type: 'public-key', alg: -7 }],
                        authenticatorSelection: {
                            userVerification: 'required',
                            residentKey: 'preferred',
                        },
                        timeout: 60000,
                        attestation: 'none',
                    },
                });

                if (!credential) {
                    setStatus('Face ID setup cancelled.', 'error');
                    return;
                }

                const credentialId = toBase64Url(new Uint8Array(credential.rawId));
                credentialInput.value = credentialId;
                setStatus('Passkey enabled for this account.', 'ok');
            } catch (e) {
                const details = e && e.name ? ` (${e.name})` : '';
                setStatus(`Face ID setup failed${details}.`, 'error');
            }
        });
    })();

    (() => {
        const btn = document.getElementById('facepp-register-btn');
        const startBtn = document.getElementById('facepp-register-start-btn');
        const stopBtn = document.getElementById('facepp-register-stop-btn');
        const status = document.getElementById('facepp-register-status');
        const video = document.getElementById('facepp-register-video');
        const canvas = document.getElementById('facepp-register-canvas');
        const tokenInput = document.getElementById('facepp-token');
        if (!btn || !startBtn || !stopBtn || !status || !video || !canvas || !tokenInput) {
            return;
        }
        let stream = null;

        const setStatus = (text, kind = '') => {
            status.textContent = text;
            status.classList.remove('ok', 'error');
            if (kind) {
                status.classList.add(kind);
            }
        };

        const stopStream = () => {
            if (stream) {
                stream.getTracks().forEach((track) => track.stop());
                stream = null;
            }
            video.srcObject = null;
        };

        startBtn.addEventListener('click', async () => {
            try {
                if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                    setStatus('Camera is not supported on this browser.', 'error');
                    return;
                }
                stopStream();
                stream = await navigator.mediaDevices.getUserMedia({
                    video: { facingMode: 'user', width: { ideal: 640 }, height: { ideal: 480 } },
                    audio: false,
                });
                video.srcObject = stream;
                setStatus('Camera opened. Center your face then capture.');
            } catch (e) {
                const details = e && e.name ? ` (${e.name})` : '';
                setStatus(`Cannot open camera${details}.`, 'error');
            }
        });

        stopBtn.addEventListener('click', () => {
            stopStream();
            setStatus('Camera stopped.');
        });

        btn.addEventListener('click', async () => {
            try {
                if (!stream || !video.videoWidth || !video.videoHeight) {
                    setStatus('Open camera first.', 'error');
                    return;
                }

                canvas.width = video.videoWidth;
                canvas.height = video.videoHeight;
                const ctx = canvas.getContext('2d');
                if (!ctx) {
                    setStatus('Camera capture context failed.', 'error');
                    return;
                }
                ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
                const blob = await new Promise((resolve) => canvas.toBlob(resolve, 'image/jpeg', 0.92));
                if (!blob) {
                    setStatus('Failed to capture image.', 'error');
                    return;
                }

                const formData = new FormData();
                formData.append('image', blob, 'facepp-register.jpg');

                setStatus('Registering Face++ token...');
                const res = await fetch('{{ path('app_facepp_enroll_token') }}', {
                    method: 'POST',
                    body: formData,
                });
                const data = await res.json();
                if (!res.ok || !data.success) {
                    setStatus(data.message || 'Face++ setup failed.', 'error');
                    return;
                }

                tokenInput.value = data.face_token || '';
                stopStream();
                setStatus('Face++ is enabled for this account.', 'ok');
            } catch (e) {
                const details = e && e.name ? ` (${e.name})` : '';
                setStatus(`Face++ setup failed${details}.`, 'error');
            }
        });

        window.addEventListener('beforeunload', stopStream);
    })();
</script>
</body>
</html>
