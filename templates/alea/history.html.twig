{% extends 'base_pages.html.twig' %}

{% block title %}My Real Cases History | Decide${% endblock %}

{% block body_class %}alea-page{% endblock %}

{% block body %}
<section class="hero">
    <div class="container text-center wrap">
        <h1>My Real Cases History</h1>
        <p>Track all your submitted requests and their status.</p>
        <div class="breadcrumbs">
            <a href="{{ path('app_home') }}">Home</a> / <a href="{{ path('app_alea') }}">Unexpected Events & Real Cases</a> / <span class="active">History</span>
        </div>
        <div class="hero-actions">
            <a class="btn-soft" href="{{ path('app_alea') }}">Back to module</a>
            <a class="btn-soft" href="{{ path('imprevu_history_stats') }}">Statistics</a>
            <a class="btn-soft" href="{{ path('imprevu_history_pdf') }}">Export PDF</a>
        </div>
    </div>
</section>

<section class="container py-5">
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="bg-white rounded p-4 shadow-sm text-center border-bottom border-success border-3">
                <h6>Total Gains</h6>
                <h3 class="text-success">+{{ totalPositif|number_format(2, ',', ' ') }} DT</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="bg-white rounded p-4 shadow-sm text-center border-bottom border-danger border-3">
                <h6>Total Expenses</h6>
                <h3 class="text-danger">-{{ totalNegatif|number_format(2, ',', ' ') }} DT</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="bg-white rounded p-4 shadow-sm text-center border-bottom border-primary border-3">
                <h6>Total Cases</h6>
                <h3 class="text-primary">{{ cas|length }}</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="bg-white rounded p-4 shadow-sm text-center border-bottom border-info border-3">
                <h6>Net</h6>
                <h3 class="{% if totalNet >= 0 %}text-success{% else %}text-danger{% endif %}">{{ totalNet|number_format(2, ',', ' ') }} DT</h3>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-12">
            <div class="bg-white rounded p-4 shadow-sm border-start border-4 border-warning">
                <h5 class="mb-3"><i class="fas fa-car-crash text-warning me-2"></i>Typologie des Risques Personnels</h5>
                <p class="mb-2">
                    Risque futur (30 jours):
                    {% if riskInsights.riskLevel == 'ELEVE' %}
                        <span class="badge bg-danger">Élevé ({{ riskInsights.riskScore }}/100)</span>
                    {% elseif riskInsights.riskLevel == 'MOYEN' %}
                        <span class="badge bg-warning text-dark">Moyen ({{ riskInsights.riskScore }}/100)</span>
                    {% else %}
                        <span class="badge bg-success">Faible ({{ riskInsights.riskScore }}/100)</span>
                    {% endif %}
                </p>
                <ul class="list-unstyled mb-2">
                    <li>🚗 Voiture: <strong>{{ riskTypology.percentages.VOITURE|number_format(0) }}%</strong></li>
                    <li>🩺 Santé: <strong>{{ riskTypology.percentages.SANTE|number_format(0) }}%</strong></li>
                    <li>🔧 Pannes maison: <strong>{{ riskTypology.percentages.PANNE_MAISON|number_format(0) }}%</strong></li>
                    <li>📦 Autres: <strong>{{ riskTypology.percentages.AUTRE|number_format(0) }}%</strong></li>
                </ul>
                <div class="alert alert-warning mb-2 py-2">{{ riskTypology.exposureMessage }}</div>
                <div class="mb-2">
                    <strong>Conseils hebdomadaires:</strong>
                    <ul class="mb-0 mt-1">
                        {% for tip in riskInsights.weeklyTips %}
                            <li>{{ tip }}</li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-white rounded shadow-sm p-3 p-md-4">
        <h5 class="mb-3"><i class="fas fa-history text-primary me-2"></i>History</h5>

        {% if cas is empty %}
            <div class="alert alert-info mb-0">No real case found yet.</div>
        {% else %}
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Title</th>
                        <th>Type</th>
                        <th>Amount</th>
                        <th>Solution</th>
                        <th>Status</th>
                        <th>Treated by</th>
                        <th>Treated at</th>
                        <th>Refusal reason</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for c in cas %}
                        <tr>
                            <td>{{ c.dateEffet ? c.dateEffet|date('d/m/Y') : '-' }}</td>
                            <td>{{ c.titre }}</td>
                            <td>
                                {% if c.type == 'POSITIF' %}
                                    <span class="badge bg-success">Gain</span>
                                {% else %}
                                    <span class="badge bg-danger">Expense</span>
                                {% endif %}
                            </td>
                            <td class="fw-bold {% if c.type == 'POSITIF' %}text-success{% else %}text-danger{% endif %}">
                                {% if c.type == 'POSITIF' %}+{% else %}-{% endif %}{{ c.montant|number_format(2, ',', ' ') }} DT
                            </td>
                            <td>{{ c.solution }}</td>
                            <td>
                                {% if c.resultat == 'VALIDE' %}
                                    <span class="badge bg-success">Validated</span>
                                {% elseif c.resultat == 'REFUSE' %}
                                    <span class="badge bg-danger">Rejected</span>
                                {% else %}
                                    <span class="badge bg-warning text-dark">Pending</span>
                                {% endif %}
                            </td>
                            <td>{{ c.confirmedBy ? (c.confirmedBy.nom ?: c.confirmedBy.email) : '-' }}</td>
                            <td>{{ c.confirmedAt ? c.confirmedAt|date('d/m/Y H:i') : '-' }}</td>
                            <td>{{ c.resultat == 'REFUSE' ? (c.raisonRefus ?: '-') : '-' }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>

    <div class="bg-white rounded shadow-sm p-3 p-md-4 mt-4">
        <h5 class="mb-3"><i class="fas fa-bell text-danger me-2"></i>Refusal Notifications</h5>
        {% set hasRefusalNotification = false %}
        {% for n in notifications %}
            {% if n.status == 'REFUSE' %}
                {% set hasRefusalNotification = true %}
            {% endif %}
        {% endfor %}

        {% if not hasRefusalNotification %}
            <div class="alert alert-info mb-0">No refusal notification.</div>
        {% else %}
            <div class="list-group">
                {% for notification in notifications %}
                    {% if notification.status == 'REFUSE' %}
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-center">
                                <strong class="text-danger">{{ notification.title }}</strong>
                                <small class="text-muted">{{ notification.createdAt ? notification.createdAt|date('d/m/Y H:i') : '-' }}</small>
                            </div>
                            <div class="mt-1">{{ notification.message }}</div>
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>
{% endblock %}
